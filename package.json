{
  "name": "course-picker",
  "private": true,
  "version": "0.0.0",
  "description": "Choose KTH courses with your friends.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:frontend",
    "build:frontend": "tsc -b && vite build",
    "build:vercel": "node scripts/vercel-build.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "convex:deploy": "convex deploy --preview-run internal.previewSeed.seed",
    "migrate:courses": "tsc -p tsconfig.scripts.json && node node_modules/.tmp/scripts/scripts/migrate-course-data.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "convex": "^1.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
